# Personal Memory Manager Environment Configuration

# Server port
PORT=8082

# Data directory for stored memories
DATA_PATH=./data

# OpenClaw workspace path for read-only browsing
WORKSPACE_PATH=/root/.openclaw/workspace

# JWT secret (auto-generated on first init, you can change it)
# JWT_SECRET=your-secret-key-here

# Admin account (change these!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=openclaw123

# OpenAI API Key - required for semantic search (optional)
# OPENAI_API_KEY=sk-xxx

# Feishu Integration (optional)
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_BASE_FOLDER_TOKEN=fold-xxx

# Enable workspace browser feature
ENABLE_WORKSPACE_BROWSER=true
